    {
      "parameters": {
        "jsCode": "const config = $input.first().json;\nconst now = new Date();\n\nfunction getMadridDate(date) {\n  return date.toLocaleString('en-CA', { timeZone: 'Europe/Madrid', year: 'numeric', month: '2-digit', day: '2-digit' });\n}\nfunction getMadridMidnightUTC(dateStr) {\n  const d = new Date(dateStr + 'T00:00:00');\n  const madridOffset = new Date(d.toLocaleString('en-US', { timeZone: 'Europe/Madrid' })) - new Date(d.toLocaleString('en-US', { timeZone: 'UTC' }));\n  return new Date(d.getTime() - madridOffset).toISOString();\n}\n\nconst todayStr = getMadridDate(now);\nconst startISO = getMadridMidnightUTC(todayStr);\nconst tomorrow = new Date(todayStr + 'T00:00:00');\ntomorrow.setDate(tomorrow.getDate() + 1);\nconst tomorrowStr = tomorrow.toISOString().split('T')[0];\nconst endISO = getMadridMidnightUTC(tomorrowStr);\n\nconst madridNow = new Date(now.toLocaleString('en-US', { timeZone: 'Europe/Madrid' }));\nconst dayOfWeek = madridNow.getDay() === 0 ? 7 : madridNow.getDay();\nconst mondayDate = new Date(madridNow);\nmondayDate.setDate(madridNow.getDate() - (dayOfWeek - 1));\nconst mondayStr = mondayDate.toISOString().split('T')[0];\nconst weekStartISO = getMadridMidnightUTC(mondayStr);\n\nreturn [{\n  json: {\n    ...config,\n    todayStr,\n    startISO,\n    endISO,\n    weekStartISO,\n  }\n}];"
      },
