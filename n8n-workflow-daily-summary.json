    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const config = $('Calcular Fechas').first().json;\n\nconst projects = $('GET Proyectos Hoy').all().map(i => i.json).filter(p => p.id);\nconst proposals = $('GET Propuestas Hoy').all().map(i => i.json).filter(p => p.id);\nconst errors = $('GET Errores Hoy').all().map(i => i.json).filter(e => e.id);\nconst weekProposals = $('GET Cuota Semanal').all().map(i => i.json).filter(w => w.id);\nconst retryItems = $('GET Retry Pendientes').all().map(i => i.json).filter(r => r.id);\n\nconst totalProjects = projects.length;\nconst totalProposals = proposals.length;\nconst totalErrors = errors.length;\nconst weekTotal = weekProposals.length;\nconst retryPending = retryItems.length;\n\nconst sent = projects.filter(p => p.status === 'sent').length;\nconst skipped = projects.filter(p => p.status === 'skipped').length;\nconst avgRelevance = totalProjects > 0\n  ? Math.round(projects.reduce((sum, p) => sum + (p.relevance_score || 0), 0) / totalProjects)\n  : 0;\nconst totalBudget = proposals.reduce((sum, p) => sum + (p.budget_suggested || 0), 0);\n\nconst relevanceBar = '█'.repeat(Math.floor(avgRelevance / 10)) + '░'.repeat(10 - Math.floor(avgRelevance / 10));\n\nconst msg = `📊 *RESUMEN DIARIO - ${config.todayStr}*\\n\\n📋 Proyectos analizados: ${totalProjects}\\n✅ Propuestas generadas: ${totalProposals}\\n📨 Enviadas auto: ${sent}\\n⏭️ Descartados: ${skipped}\\n❌ Errores: ${totalErrors}\\n🔄 En cola de reintento: ${retryPending}\\n🎯 Relevancia media: ${relevanceBar} ${avgRelevance}/100\\n💶 Valor total propuestas: €${totalBudget}\\n\\n📅 *Cuota semanal:* ${weekTotal} propuestas\\n\\n${totalErrors > 3 ? '⚠️ Demasiados errores hoy. Revisa los logs.' : '✅ Sistema operando correctamente.'}`;\n\nreturn [{\n  json: {\n    ...config,\n    message: msg,\n  }\n}];"
      },
